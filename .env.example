# Product RCA application settings. Copy to .env and adjust locally.
# Add a local provider credential for live System A/B/C runs. Never commit it.
OPENAI_API_KEY=

RCA_SOURCE_DUCKDB_PATH=data/events.duckdb
RCA_RUNTIME_DUCKDB_PATH=runtime/events.duckdb
RCA_CHROMA_PERSIST_PATH=runtime/chroma

RCA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RCA_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RCA_LLM_MODEL=gpt-5.4-nano
# OPENAI_MODEL is also accepted as a compatibility alias.

RCA_BM25_CANDIDATE_COUNT=30
RCA_DENSE_CANDIDATE_COUNT=30
RCA_RERANK_CANDIDATE_COUNT=20
RCA_RETRIEVAL_TOP_K=8
RCA_RRF_CONSTANT=60
RCA_INDEX_BATCH_SIZE=64
RCA_MAX_CHUNKS_PER_PARENT=2

RCA_SQL_RESULT_ROW_LIMIT=200
RCA_MINIMUM_SEGMENT_SIZE=50
RCA_SYSTEM_B_MAX_TOOL_CALLS=15
RCA_SYSTEM_B_MAX_RETRIEVAL_CALLS=4
RCA_SYSTEM_B_MAX_ANALYTICAL_CALLS=10
RCA_SYSTEM_C_MAX_REVISIONS=2
RCA_SYSTEM_C_MAX_NODE_EXECUTIONS=60
RCA_TOOL_TIMEOUT_SECONDS=30
RCA_NODE_TIMEOUT_SECONDS=60
RCA_MAX_HYPOTHESES=5
RCA_MAX_PROMPT_CHUNKS=12
RCA_MAX_CHUNK_CHARACTERS=6000
RCA_QUERY_TIMEOUT_SECONDS=30
RCA_LOG_LEVEL=INFO
RCA_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
